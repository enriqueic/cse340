<% if (title) { %>
  <h1><%= title %></h1>
<% } else {
  res.redirect('/')
} %>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form class="auth-form" action="/inv/add-classification" method="post">
  <label for="classification_name">Classification Name</label>
  <input
    type="text"
    id="classification_name"
    name="classification_name"
    placeholder="Enter classification name"
    pattern="^[A-Za-z0-9]+$"
    title="Classification names may only contain letters and numbers with no spaces or special characters."
    required
    value="<%= classification_name ? classification_name : '' %>"
  />
  <p class="field-help">
    Classification names cannot contain spaces or special characters.
  </p>

  <button type="submit">Add Classification</button>
</form>
