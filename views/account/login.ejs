<form class="auth-form" action="/account/login" method="post">
  <h1><%= title %></h1>
  <%- messages() %>

  <label for="account_email">Email:</label>
  <input type="email" id="account_email" name="account_email" placeholder="Enter your email" required />

  <label for="account_password">Password:</label>
  <span class="password-reminder">Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span>
  <input type="password" id="account_password" name="account_password" placeholder="Enter your password" pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$" required />

  <button type="submit">Login</button>

  <p class="account-footer">
    No account? <a href="/account/register">Sign-up</a>
  </p>
</form>